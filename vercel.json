{
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python",
            "config": { "maxLambdaSize": "15mb", "runtime": "python3.11" }
        },
        {
            "src": "static/",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        { "src": "/static/(.*)", "dest": "/static/$1" },
        { "src": "/media/(.*)", "dest": "/media/$1" },
        { "src": "/(.*)", "dest": "api/index.py" }
    ],
    "env": {
        "DJANGO_SETTINGS_MODULE": "core.settings"
    }
}